    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.3.1",
    "react-is": "^18.3.1",
